# ─── Bind IPs ───
APP_BIND_IP=0.0.0.0
LOCAL_BIND_IP=127.0.0.1

# ─── Ports ───
NGINX_PORT=8080
ADMINER_PORT=8081
MINIO_CONSOLE_PORT=8082
MILVUS_WEBUI_PORT=8083
REDIS_INSIGHT_PORT=8084
RABBITMQ_MANAGEMENT_PORT=8085
PROMETHEUS_PORT=8086
FRONTEND_PORT=5173
BACKEND_PORT=8000
OLLAMA_PORT=11434

# ─── Database (PostgreSQL) ───
POSTGRES_DB=omnicall
POSTGRES_USER=omnicall
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Cache (Redis) ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_PROCESSING_LOCK_TTL_SECONDS=900

# ─── Queue (RabbitMQ) ───
RABBITMQ_USER=omnicall
RABBITMQ_PASSWORD=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_COUNT=4
PROCESSING_RECONCILIATION_INTERVAL_SECONDS=60
PROCESSING_RECONCILIATION_STALE_SECONDS=120
PROCESSING_RECONCILIATION_BATCH_SIZE=100

# ─── Object Storage (MinIO) ───
MINIO_ROOT_USER=omnicall
MINIO_ROOT_PASSWORD=change-me
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=omnicall-meetings
MINIO_SECURE=false

# ─── Vector Database (Milvus) ───
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=meeting_chunks
MILVUS_BUCKET=milvus-data
VECTOR_PROVIDER=milvus

# ─── Monitoring (Prometheus) ───
PROMETHEUS_URL=http://prometheus:9090
ADMIN_METRICS_CACHE_KEY=admin:metrics:snapshot
ADMIN_METRICS_CACHE_TTL_SECONDS=10
OPERATIONAL_LOG_STREAM_KEY=admin:logs:operational
OPERATIONAL_LOG_MAX_LENGTH=1000
OPERATIONAL_LOG_TTL_SECONDS=86400
OPERATIONAL_LOG_DEFAULT_TAIL=100
AUTH_SESSION_TTL_HOURS=168

# ─── App Services ───
APP_NAME=Omnicall API
APP_ENV=local
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
UPLOAD_MAX_BYTES=524288000
UPLOAD_ALLOWED_EXTENSIONS=[".aac",".m4a",".mp3",".mp4",".wav",".webm",".txt",".md",".vtt",".srt"]
UPLOAD_ALLOWED_CONTENT_TYPES=["audio/aac","audio/m4a","audio/mpeg","audio/mp4","audio/wav","audio/webm","video/mp4","video/webm","text/plain","text/markdown","text/vtt","application/x-subrip"]

# ─── Local Model Runtime ───
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BOOTSTRAP_MODELS=qwen2.5:1.5b nomic-embed-text llama-guard3:1b
MODEL_CACHE_DIR=/models
HF_HOME=/models/.hf-cache

# ─── Local Models ───
VOICE_FFMPEG_PATH=ffmpeg
VOICE_WORK_DIR=/tmp/omnicall-audio
VAD_MIN_SPEECH_MS=300
VAD_SILENCE_GAP_MS=500
VAD_ENERGY_THRESHOLD=0.012
ASR_MODEL=whisper-small-int8
ASR_COMPUTE_TYPE=int8
ASR_COMMAND=python -m backend.model_runners.asr --audio-path {audio_path} --model-dir {model_cache_dir}/asr --model-name {model} --compute-type {compute_type}
ASR_HF_REPO=Systran/faster-whisper-small
ASR_HF_REVISION=main
ASR_DOWNLOAD_COMMAND=
ASR_TIMEOUT_SECONDS=120
ASR_TIMEOUT_REALTIME_FACTOR=1.0
DIARIZATION_MODEL=wespeaker-voxceleb-resnet34
DIARIZATION_COMMAND=python -m backend.model_runners.diarization --audio-path {audio_path} --model-dir {model_cache_dir}/diarization --device cpu
DIARIZATION_HF_REPO=Wespeaker/wespeaker-voxceleb-resnet34-LM
DIARIZATION_HF_REVISION=main
DIARIZATION_DOWNLOAD_COMMAND=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_TIMEOUT_SECONDS=30
RERANK_MODEL=bge-reranker-v2-m3
RERANK_COMMAND=python -m backend.model_runners.rerank --model-dir {model_cache_dir}/rerank --model-name {model}
RERANK_HF_REPO=BAAI/bge-reranker-v2-m3
RERANK_HF_REVISION=main
RERANK_DOWNLOAD_COMMAND=
RERANK_TOP_K=12
RERANK_OUTPUT_K=6
RERANK_TIMEOUT_SECONDS=30
GUARDRAIL_MODEL=llama-guard3:1b
GUARDRAIL_TIMEOUT_SECONDS=20
GUARDRAIL_MAX_RETRIES=0
GUARDRAIL_INPUT_ENABLED=true
GUARDRAIL_TRANSCRIPT_ENABLED=true
GUARDRAIL_CONTEXT_ENABLED=true
GUARDRAIL_OUTPUT_ENABLED=true
GUARDRAIL_STRICT_MODE=false

LLM_PROVIDER=endpoint
LLM_API_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=change-me
LLM_MODEL=change-me
LLM_ENDPOINT_COMPATIBILITY=openai
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=0.2
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_LLM_TIMEOUT_SECONDS=600
OLLAMA_CONTEXT_LENGTH=8192

# ─── Global ───
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO
