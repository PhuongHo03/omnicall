# ─── Bind IPs ───
APP_BIND_IP=0.0.0.0
LOCAL_BIND_IP=127.0.0.1

# ─── Ports ───
NGINX_PORT=8080
ADMINER_PORT=8081
MINIO_CONSOLE_PORT=8082
MILVUS_WEBUI_PORT=8083
REDIS_INSIGHT_PORT=8084
RABBITMQ_MANAGEMENT_PORT=8085
PROMETHEUS_PORT=8086
FRONTEND_PORT=5173
BACKEND_PORT=8000
OLLAMA_PORT=11434

# ─── Database (PostgreSQL) ───
POSTGRES_DB=omnicall
POSTGRES_USER=omnicall
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Cache (Redis) ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_PROCESSING_LOCK_TTL_SECONDS=900

# ─── Queue (RabbitMQ) ───
RABBITMQ_USER=omnicall
RABBITMQ_PASSWORD=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_COUNT=4
PROCESSING_RECONCILIATION_INTERVAL_SECONDS=60
PROCESSING_RECONCILIATION_STALE_SECONDS=120
PROCESSING_RECONCILIATION_BATCH_SIZE=100
CHAT_TURN_LEASE_SECONDS=300

# ─── Object Storage (MinIO) ───
MINIO_ROOT_USER=omnicall
MINIO_ROOT_PASSWORD=change-me
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=omnicall-meetings
MINIO_SECURE=false

# ─── Vector Database (Milvus) ───
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=meeting_chunks
MILVUS_BUCKET=milvus-data
VECTOR_PROVIDER=milvus

# ─── Monitoring (Prometheus) ───
PROMETHEUS_URL=http://prometheus:9090
ADMIN_METRICS_CACHE_KEY=admin:metrics:snapshot
ADMIN_METRICS_CACHE_TTL_SECONDS=10
OPERATIONAL_LOG_STREAM_KEY=admin:logs:operational
OPERATIONAL_LOG_MAX_LENGTH=1000
OPERATIONAL_LOG_TTL_SECONDS=86400
OPERATIONAL_LOG_DEFAULT_TAIL=100
AUTH_SESSION_TTL_HOURS=168
LLM_PROMPT_DATA_POLICY=trusted

# ─── App Services ───
APP_NAME=Omnicall API
APP_ENV=local
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
UPLOAD_MAX_BYTES=524288000
UPLOAD_ALLOWED_EXTENSIONS=[".aac",".m4a",".mp3",".mp4",".wav",".webm"]
UPLOAD_ALLOWED_CONTENT_TYPES=["audio/aac","audio/m4a","audio/mpeg","audio/mp4","audio/wav","audio/webm","video/mp4","video/webm"]

# ─── Resilience ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_MEETINGS_PER_MINUTE=300
RATE_LIMIT_ADMIN_PER_MINUTE=180
RATE_LIMIT_PUBLIC_PER_MINUTE=10
CONCURRENCY_LIMIT_PER_ACCOUNT=5
CONCURRENCY_LIMIT_MEETINGS=5
CONCURRENCY_LIMIT_ADMIN=3
CONCURRENCY_LIMIT_AUTH=3
TASK_LIMIT_PER_MEETING=2
TASK_LIMIT_PER_USER=5
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ─── Local Model Runtime ───
OLLAMA_BASE_URL=http://ollama:11434

# ─── Local Models ───
VAD_MIN_SPEECH_MS=300
VAD_SILENCE_GAP_MS=500
VAD_ENERGY_THRESHOLD=0.012
ASR_TIMEOUT_SECONDS=120
ASR_TIMEOUT_REALTIME_FACTOR=1.0
ASR_MODEL=whisper-medium
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=5
ASR_LANGUAGE=auto
ASR_MIN_SEGMENT_CONFIDENCE=0.1
ASR_MAX_NO_SPEECH_PROBABILITY=0.6
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_SECONDS=0.2
EMBEDDING_CONTRACT_VERSION=v1
RERANK_TOP_K=12
RERANK_OUTPUT_K=6
RERANK_TIMEOUT_SECONDS=30
RETRIEVAL_FALLBACK_CANDIDATE_LIMIT=48
RETRIEVAL_TRIGRAM_THRESHOLD=0.12
GUARDRAIL_MODEL=llama-guard3:1b
GUARDRAIL_TIMEOUT_SECONDS=20
GUARDRAIL_MAX_RETRIES=1
GUARDRAIL_INPUT_ENABLED=true
GUARDRAIL_OUTPUT_ENABLED=true
GUARDRAIL_STRICT_MODE=false
GUARDRAIL_PII_REDACTION_ENABLED=true

# ─── Simple Evidence-First RAG ───
DEFAULT_CHAT_LANGUAGE=en
RAG_QUERY_INTERPRETATION_TIMEOUT_SECONDS=15
RAG_EVIDENCE_RETRIEVAL_TIMEOUT_SECONDS=20
RAG_SYNTHESIS_PRIMARY_TIMEOUT_SECONDS=60
RAG_SYNTHESIS_FALLBACK_TIMEOUT_SECONDS=40
RAG_FINALIZATION_RESERVE_SECONDS=15
RAG_CHAT_TURN_TIMEOUT_SECONDS=150
RAG_SYNTHESIS_CONTRACT_RETRIES=1
LLM_REASONING_MODE=disabled
LLM_PROVIDER=endpoint
LLM_API_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=change-me
LLM_MODEL=change-me
LLM_ENDPOINT_COMPATIBILITY=openai
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=0.2
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_LLM_TIMEOUT_SECONDS=600
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_MAX_OUTPUT_TOKENS=1024
EXTRACTION_WINDOW_TARGET_TOKENS=2000
EXTRACTION_WINDOW_HARD_LIMIT_TOKENS=2800
EXTRACTION_WINDOW_OVERLAP_SEGMENTS=1
EXTRACTION_WINDOW_MAX_WORKERS=4

# ─── Global ───
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO
