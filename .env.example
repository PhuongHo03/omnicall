# ─── Bind IPs ───
APP_BIND_IP=0.0.0.0
LOCAL_BIND_IP=127.0.0.1

# ─── Ports ───
NGINX_PORT=8080
FRONTEND_PORT=5173
BACKEND_PORT=8000
ADMINER_PORT=8081
REDIS_INSIGHT_PORT=5540
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_CONSOLE_PORT=9001
PROMETHEUS_PORT=9096

# ─── Database (PostgreSQL) ───
POSTGRES_DB=omnicall
POSTGRES_USER=omnicall
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Cache (Redis) ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_PROCESSING_LOCK_TTL_SECONDS=900

# ─── Queue (RabbitMQ) ───
RABBITMQ_USER=omnicall
RABBITMQ_PASSWORD=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_COUNT=4

# ─── Object Storage (MinIO) ───
MINIO_ROOT_USER=omnicall
MINIO_ROOT_PASSWORD=change-me
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=omnicall-meetings
MINIO_SECURE=false

# ─── Vector Database (Milvus) ───
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=meeting_chunks
MILVUS_BUCKET=milvus-data
VECTOR_PROVIDER=milvus

# ─── Monitoring (Prometheus) ───
PROMETHEUS_URL=http://prometheus:9090
ADMIN_METRICS_CACHE_KEY=admin:metrics:snapshot
ADMIN_METRICS_CACHE_TTL_SECONDS=10

# ─── App Services ───
APP_NAME=Omnicall API
APP_ENV=local
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
UPLOAD_MAX_BYTES=524288000
UPLOAD_ALLOWED_EXTENSIONS=[".aac",".m4a",".mp3",".mp4",".wav",".webm",".txt",".md",".vtt",".srt"]
UPLOAD_ALLOWED_CONTENT_TYPES=["audio/aac","audio/m4a","audio/mpeg","audio/mp4","audio/wav","audio/webm","video/mp4","video/webm","text/plain","text/markdown","text/vtt","application/x-subrip"]

# ─── Model Providers ───
ASR_PROVIDER=local
SPEAKER_EMBEDDING_PROVIDER=wespeaker
ANALYSIS_PROVIDER=local
TEXT_EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSIONS=64
RERANK_PROVIDER=local

LLM_PROVIDER=endpoint
LLM_API_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=change-me
LLM_MODEL=change-me
LLM_ENDPOINT_COMPATIBILITY=openai
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=0.2
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

# ─── Global ───
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO
